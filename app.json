{
  "expo": {
    "name": "FORGE",
    "slug": "forge-athlete",
    "owner": "zordon",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "react-native-health-connect",
      "expo-secure-store"
    ],
    "ios": {
      "bundleIdentifier": "com.zordontech.forge",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSHealthShareUsageDescription": "FORGE reads Apple Health workout data to import your performance history.",
        "NSHealthUpdateUsageDescription": "FORGE writes run and strength workout data to Apple Health.",
        "NSLocationWhenInUseUsageDescription": "FORGE uses your location during run tracking to calculate distance and pace.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "package": "com.forgeathlete.app",
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "6aeb5fbb-2697-4cf4-b9b3-afe60c63e9e1"
      }
    },
    "icon": "./assets/icon.png",
    "newArchEnabled": false
  }
}